{
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:examples && make -C ../.. demo-wasm && vite build",
    "build:examples": "node scripts/build-examples.mjs",
    "deploy": "npm run build && wrangler deploy",
    "dev": "npm run build:examples && make -C ../.. demo-wasm && vite --host 0.0.0.0",
    "preview": "npm run build && wrangler dev",
    "serve": "vite preview --host 0.0.0.0"
  },
  "dependencies": {
    "alpinejs": "^3.15.0"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "autoprefixer": "^10.4.22",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "vite": "^7.2.4",
    "wrangler": "^4.90.1"
  }
}
